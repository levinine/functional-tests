# Jira Ticket Fetcher — Environment Variables
# Copy this file to .env and fill in your values.
# Place .env next to the script (scripts/.env) or in the project root.

# --- Jira Cloud ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_USER_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token

# --- Jira Server / Data Center (use PAT instead of email+token) ---
# JIRA_BASE_URL=https://jira.yourcompany.com
# JIRA_PAT=your-personal-access-token

# --- GitHub Issues ---
# GITHUB_TOKEN=ghp_your-github-personal-access-token
# Generate at: https://github.com/settings/tokens (needs "repo" scope for private repos)
